# Supabase — get these from supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth — generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000

# AWS — IAM user needs S3 PutObject/DeleteObject + SES SendEmail permissions
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=your-bucket-name
SES_FROM_EMAIL=no-reply@yourdomain.com

# MercadoPago — get these from mercadopago.com → Developers → Credentials
MERCADOPAGO_ACCESS_TOKEN=your-mp-access-token
MERCADOPAGO_PUBLIC_KEY=your-mp-public-key
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=your-mp-public-key
